# =============================================================================
# Kandarp OS — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local` (it is gitignored).
#
# Rules (coding-standards §8):
#   - Anything prefixed with NEXT_PUBLIC_ is exposed to the browser. Audit every use.
#   - Server-only secrets must NOT be prefixed with NEXT_PUBLIC_.
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# Public base URL of the deployed site (used for metadata + OG tags).
NEXT_PUBLIC_SITE_URL="https://kandarp-os.dev"

# -----------------------------------------------------------------------------
# Contact Form (server-only — /api/contact)
# -----------------------------------------------------------------------------
# Email service provider API key (e.g. Resend, SendGrid). Server-only.
CONTACT_EMAIL_API_KEY=""

# Address that contact form submissions are delivered to.
CONTACT_EMAIL_TO="hello@kandarp-os.dev"

# Address the contact form sends from (verified with the email provider).
CONTACT_EMAIL_FROM="portfolio@kandarp-os.dev"

# -----------------------------------------------------------------------------
# Analytics (privacy-respecting — Plausible/Umami)
# -----------------------------------------------------------------------------
# Public analytics script src (exposed to the browser on purpose).
NEXT_PUBLIC_ANALYTICS_SRC=""

# Public analytics site/domain id.
NEXT_PUBLIC_ANALYTICS_DOMAIN="kandarp-os.dev"

# -----------------------------------------------------------------------------
# Error Tracking (Sentry)
# -----------------------------------------------------------------------------
# Public Sentry DSN (safe to expose — it only accepts inbound events).
NEXT_PUBLIC_SENTRY_DSN=""

# Sentry org + project for server-side release tracking (server-only).
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# -----------------------------------------------------------------------------
# Admin Console (server-only)
# -----------------------------------------------------------------------------
# 32+ byte random string used to HMAC-sign session JWTs. REQUIRED in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_JWT_SECRET=""

# Default owner account seeded on first boot if no users exist. CHANGE IMMEDIATELY.
ADMIN_OWNER_EMAIL="admin@kandarp-os.dev"
ADMIN_OWNER_PASSWORD="ChangeMe!2026"

# Absolute path to the JSON store root. Defaults to `.admin-data`.
ADMIN_DATA_DIR=".admin-data"

# -----------------------------------------------------------------------------
# GitHub Integration (server-only — /api/projects)
# -----------------------------------------------------------------------------
# Personal access token for fetching repos. Server-only; never expose.
GITHUB_TOKEN=""
