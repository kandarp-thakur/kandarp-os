{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@backend/*": [
                "./src/backend/*"
            ],
            "@packages/*": [
                "./src/packages/*"
            ],
            "@features/*": [
                "./src/features/*"
            ],
            "@config/*": [
                "./src/packages/config/*"
            ],
            "@hooks/*": [
                "./src/packages/hooks/*"
            ],
            "@utils/*": [
                "./src/packages/utils/*"
            ],
            "@services/*": [
                "./src/services/*"
            ],
            "@data/*": [
                "./src/data/*"
            ],
            "@styles/*": [
                "./src/infrastructure/styles/*"
            ],
            "@assets/*": [
                "./src/assets/*"
            ],
            "@providers": [
                "./src/infrastructure/providers/index.tsx"
            ],
            "@providers/*": [
                "./src/infrastructure/providers/*"
            ],
            "@3d/*": [
                "./src/infrastructure/three/*"
            ],
            "@lib/*": [
                "./src/lib/*"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}