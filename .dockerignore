# ──────────────────────────────────────────────────────────────────────
# .dockerignore — keeps the build context small and prevents secrets /
# dev artefacts from leaking into the Docker image.
# ──────────────────────────────────────────────────────────────────────

# Version control
.git
.gitignore
.gitattributes

# Dependencies (reinstalled inside the container)
node_modules
**/node_modules

# Next.js build output (rebuilt inside the container)
.next
.next.cache
out
build
dist

# TypeScript build info
*.tsbuildinfo
tsconfig.tsbuildinfo

# Environment files — NEVER copy into the image. Pass via --env-file or
# environment variables at runtime.
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.idea
.vscode
*.swp
*.swo

# Documentation (not needed at runtime)
docs
README.md
*.md

# Test / coverage artefacts
coverage
.nyc_output
test
tests
__tests__
*.spec.ts
*.spec.tsx
*.test.ts
*.test.tsx

# CI / scripts (not needed at runtime)
.github
scripts/refactor

# Docker artefacts (avoid recursive context bloat)
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml

# Misc
h.html
about_raw.html
tsc-errors*.txt
host-nextjs-on-vercel.pdf
