# npm install configuration
#
# `legacy-peer-deps` defuses peer-dependency resolution errors (ERESOLVE)
# that occur on fresh installs in CI/Vercel when React 19 is used with
# packages that still declare peer ranges of React 18 (e.g. some
# @react-three/* and framer-motion transitive deps). Locally the
# node_modules already exists so the conflict never surfaces, but a
# clean install on the Vercel build server fails without this flag.
legacy-peer-deps=true
